---
const steps = [
  { title: 'Subes la imagen', description: 'Al coordinator vía HTTP' },
  {
    title: 'El coordinator la guarda',
    description: 'En MinIO y crea una tarea SLICE en Redis',
  },
  {
    title: 'Los workers procesan',
    description: 'Toman tareas de la cola y procesan fragmentos en paralelo',
  },
  {
    title: 'Obtienes el resultado',
    description: 'Se guarda en MinIO y se notifica al frontend',
  },
];
---

<section class="border-t bg-muted/30 px-6 py-16">
  <div class="mx-auto max-w-4xl">
    <h3 class="mb-8 text-center text-2xl font-semibold">Cómo funciona</h3>
    <div class="flex flex-col items-center gap-4">
      {steps.map((step, i) => (
        <>
          <div class="flex items-center gap-3">
            <div class="flex size-10 items-center justify-center rounded-full bg-primary text-sm font-bold text-primary-foreground">{i + 1}</div>
            <div class="rounded-2xl border bg-card px-5 py-3">
              <p class="font-medium">{step.title}</p>
              <p class="text-sm text-muted-foreground">{step.description}</p>
            </div>
          </div>
          {i < steps.length - 1 && <div class="h-6 w-px bg-border" />}
        </>
      ))}
    </div>
  </div>
</section>
