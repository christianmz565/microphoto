---
const features = [
  {
    title: 'Procesamiento paralelo',
    description:
      'Las imágenes se dividen en fragmentos y se procesan concurrentemente entre múltiples workers.',
    icon: 'stack',
  },
  {
    title: 'Tolerancia a fallos',
    description:
      'Un servicio reaper detecta tareas atascadas y las reprograma automáticamente.',
    icon: 'refresh',
  },
  {
    title: 'Observabilidad',
    description:
      'Métricas de Prometheus y dashboards de Grafana en tiempo real.',
    icon: 'chart',
  },
  {
    title: 'Escalable',
    description:
      'Los workers son stateless y se pueden escalar horizontalmente según la carga.',
    icon: 'server',
  },
];
---

<section class="border-t px-6 py-16">
  <div class="mx-auto max-w-4xl">
    <h3 class="mb-8 text-center text-2xl font-semibold">Características</h3>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((f) => (
        <div class="flex flex-col gap-3 rounded-2xl border p-5">
          <div class="flex size-10 items-center justify-center rounded-full bg-primary/10">
            {f.icon === 'stack' && (
              <svg class="size-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/><path d="m8 16 4-4 4 4"/><path d="m8 8 4 4 4-4"/></svg>
            )}
            {f.icon === 'refresh' && (
              <svg class="size-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg>
            )}
            {f.icon === 'chart' && (
              <svg class="size-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
            )}
            {f.icon === 'server' && (
              <svg class="size-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>
            )}
          </div>
          <h4 class="font-medium">{f.title}</h4>
          <p class="text-sm text-muted-foreground">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
