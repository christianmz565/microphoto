---
const filters = [
  {
    title: 'Escala de grises',
    description: 'Convierte la imagen a blanco y negro.',
  },
  {
    title: 'Desenfoque',
    description: 'Aplica un desenfoque gaussiano con radio configurable.',
  },
  {
    title: 'Brillo',
    description: 'Ajusta el brillo con un factor multiplicativo.',
  },
  {
    title: 'Redimensionar',
    description: 'Cambia las dimensiones de la imagen.',
  },
];
---

<section class="border-t px-6 py-16">
  <div class="mx-auto max-w-4xl">
    <h3 class="mb-8 text-center text-2xl font-semibold">Filtros disponibles</h3>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {filters.map((f) => (
        <div class="flex flex-col gap-2 rounded-2xl border p-5">
          <h4 class="font-medium">{f.title}</h4>
          <p class="text-sm text-muted-foreground">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
